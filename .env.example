# ── Gemini API Credentials ──────────────────────────────────────
GEMINI_API_KEY=paste_your_actual_key_here
GOOGLE_GENAI_USE_ENTERPRISE=FALSE

# ── Model Selection ──────────────────────────────────────────────
# Visual Forensics Agent uses the full Flash model for image analysis
# gemini-2.5-flash: 10 RPM / 250 RPD on free tier
TRUTHGUARD_VISION_MODEL=gemini-2.5-flash

# Context Verification and Triage Agents use Flash-Lite
# gemini-2.5-flash-lite: 30 RPM / 1000 RPD on free tier — 4x more headroom
# Flash-Lite is sufficient for structured JSON tasks with explicit prompts
TRUTHGUARD_TEXT_MODEL=gemini-2.5-flash-lite

# ── Quota Safety Settings ────────────────────────────────────────
# Seconds to wait between consecutive Gemini API calls
# At 2.0s delay, sub-claim searches stay well under 30 RPM limit
TRUTHGUARD_API_CALL_DELAY=2.0

# Maximum retry attempts when a 429 quota error is returned
TRUTHGUARD_MAX_RETRIES=3

# Base wait in seconds for exponential backoff (doubles each retry)
# Attempt 1: wait 10s  |  Attempt 2: wait 20s  |  Attempt 3: wait 40s
TRUTHGUARD_RETRY_BASE_WAIT=10

# ── Session Settings ─────────────────────────────────────────────
TRUTHGUARD_SESSION_DIR=/tmp/truthguard
TRUTHGUARD_MAX_IMAGE_SIZE_MB=10
TRUTHGUARD_LOG_LEVEL=INFO

